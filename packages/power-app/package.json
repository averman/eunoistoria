{
  "name": "@eunoistoria/power-app",
  "version": "0.1.0",
  "private": true,
  "main": "out/main/bootstrap.cjs",
  "scripts": {
    "dev": "node scripts/build-main.js --watch & vite --host",
    "build": "node scripts/build-main.js && vite build",
    "preview": "electron .",
    "pack": "electron-builder --publish never",
    "dist": "pnpm build && electron-builder",
    "test": "vitest run"
  },
  "dependencies": {
    "@eunoistoria/engine": "workspace:*",
    "@eunoistoria/adapter-sqlite": "workspace:*",
    "@eunoistoria/types": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.4.0",
    "archiver": "^7.0.0",
    "unzipper": "^0.11.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "vitest": "^1.6.1",
    "@types/unzipper": "^0.10.0",
    "@types/archiver": "^6.0.2",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.eunoistoria.power-app",
    "productName": "Eunoistoria",
    "files": [
      "out/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  }
}